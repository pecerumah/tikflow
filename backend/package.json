{
  "name": "tikflow-worker",
  "version": "1.0.0",
  "description": "TikFlow — Cloudflare Worker Backend",
  "main": "worker.js",
  "scripts": {
    "dev": "wrangler dev --env development",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "db:init": "wrangler d1 execute tikflow-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute tikflow-db --remote --file=schema.sql",
    "db:console": "wrangler d1 execute tikflow-db --command=\"SELECT * FROM users\"",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^4.72.0"
  }
}
